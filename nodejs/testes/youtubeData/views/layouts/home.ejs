<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home somente logado</title>
     <style>
        body {
            background-color: #191919;
            color: white;
        }

        .c-auth {
            position: absolute;
            top: 15px;
            right: 20px;

            padding: 8px;
            border-radius: 5px;
            box-shadow: 2px 2px 5px azure;
            background-color: #191919;
            color: aliceblue;

            display: flex;
            align-items: center;
            gap: 15px;
        }
        button {
            background-color: #191919;
            color: aliceblue;
            border: none;
            padding: 2px 25px;
            height: 40px;
            box-shadow: 1px 1px 2px #999;        
        }

        a {
            color: inherit;
            text-decoration: none;
            outline: none;
        }

        nav {
            width: fit-content;
            height: 100vh;
            padding: 20px;
        }
        ul {
            list-style: none;
        }

        .c-auth section {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .c-auth section img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }
        .c-auth section div strong,p {
            font-size: 11px;
        }

        .c-message {
            width: 150px;
            height: 89px;
            position: absolute;
            bottom: 10px;
            right: 20px;
            background-color: wheat;
            border-radius: 10px;
        }
        .m-title {
            color: #191919;
            text-align: center;
        }
    </style>
</head>
<body>
    <h1>Home</h1>

    <div id="notify"></div>

   <%- include('../partials/googleOauthLogout') %>

    <section id="c-home">
        <%- include('../partials/menu') %>    
    </section>

    <script type="module" src="/scripts/me.js"></script>
    <script>
        const eventSource = new EventSource("/events");

        eventSource.addEventListener('notification' , (event) => {
            const data = JSON.parse(event.data)
            console.log(data);
            notify(data)
        })

        function notify(data) {
            const notifyContainer = document.createElement('div')
            notifyContainer.setAttribute('data-alta-id', data.id)
            notifyContainer.classList.add('c-message')

            const notifyTitle = document.createElement('h1')
            notifyTitle.classList.add('m-title')
            notifyTitle.textContent = data.quanty

            notifyContainer.appendChild(notifyTitle)

            document.getElementById('notify').appendChild(notifyContainer)
        }
    </script>
</body>
</html>
