    <title>Home somente logado</title>
     <style>
        body {
            background-color: #191919;
            color: white;
        }

        .c-auth {
            position: absolute;
            top: 15px;
            right: 20px;

            padding: 8px;
            border-radius: 5px;
            box-shadow: 2px 2px 5px azure;
            background-color: #191919;
            color: aliceblue;

            display: flex;
            align-items: center;
            gap: 15px;
        }
        button {
            background-color: #191919;
            color: aliceblue;
            border: none;
            padding: 2px 25px;
            height: 40px;
            box-shadow: 1px 1px 2px #999;        
        }

        a {
            color: inherit;
            text-decoration: none;
            outline: none;
        }

        nav {
            width: fit-content;
            height: 100vh;
            padding: 20px;
        }
        ul {
            list-style: none;
        }

        .c-auth section {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .c-auth section img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }
        .c-auth section div strong,p {
            font-size: 11px;
        }

        .c-message {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 250px;
            height: 55px;
            position: absolute;
            bottom: 50px;
            right: 20px;
            background-color: wheat;
            border-radius: 10px;
        }
        .m-title {
            color: #191919;
            margin: 0px 0px 2px 0px;
            text-align: center;
            font-size: 15px;
        }
        .m-type {
            color: #212121;
            font-size: 12px;
        }
        #toast-container{

            /* position:fixed;

            top:20px;
            right:20px;

            width:250px; */

            display:flex;

            flex-direction:column;

            gap:12px;

            z-index:9999;

        }

        .toast{
            position: absolute;
            bottom: 50px;
            right: 20px;
            width: 355px;
            background:#191919;

            border-radius:10px;

            overflow:hidden;

            box-shadow: 2px 2px 5px azure;

            animation:toastShow .3s ease;

        }

        .toast-header{

            display:flex;

            justify-content:space-between;

            align-items:center;

            padding:12px 16px;

            border-bottom:1px solid #eee;

        }

        .toast-body{

            padding:16px;

        }

        .toast-close{

            background:none;

            border:none;

            cursor:pointer;

            font-size:18px;

        }

        .toast-progress{

            height:4px;

            width:100%;

            background:#0d6efd;

        }

        .toast-hide{

            animation:toastHide .3s forwards;

        }

        @keyframes toastShow{

            from{

                opacity:0;

                transform:translateX(100%);

            }

            to{

                opacity:1;

                transform:translateX(0);

            }

        }

        @keyframes toastHide{

            to{

                opacity:0;

                transform:translateX(100%);

            }

        }
    </style>
</head>
<body>
    <h1>Home</h1>

    <div id="notify"></div>

   <%- include('../partials/googleOauthLogout') %>

